/*
* Encapsulation example 
*/

//Paddle.java

public class Paddle {
	// variables are now private
	private String name;
	private int height;
	private int width;
	private String color;
	
	//public getter functions
	
	public String getName() {
		return name;
	}
	
	public int getHeight() {
		return height;
	}
	
	public int getWidth() {
		return width;
	}
	
	public String getColor() {
		return color;
	}
	
	// Public setter methods
	
	public void setName(String newName) {
		name = newName;
	}
	
	public void setHeight(int newHeight) {
		height = newHeight;
	}
	
	public void setWidth(int newWidth) {
		width = newWidth;
	}
	
	public void setColor(String newColor) {
		color = newColor;
	}
	
}



// Main.java 

public class Main {
	public static void main(String[] args) {
		System.out.println("Encapsulation example");
		
		//create object from class
		Paddle Paddle1 = new Paddle();
		
		// Use setter methods to get object properties
		Paddle1.setName("Paddle1");
		Paddle1.setHeight(200);
		Paddle1.setWidth(500);
		Paddle1.setColor("FFF00");
		
		
		/*
		 * Display the attributes of this new Objects using getter
		 */
		
		System.out.println("Name: " + Paddle1.getName());
		System.out.println("height: " + Paddle1.getHeight());
		System.out.println("width: " + Paddle1.getWidth());
		System.out.println("color: " + Paddle1.getColor());
	}
}


